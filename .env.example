# Optional later-wave secret placeholder. Inject a real value through the local environment only.
OPENAI_API_KEY=replace-with-an-environment-secret

# Local development origins. These values contain no credentials.
NEXT_PUBLIC_CLAIMDONE_API_ORIGIN=http://127.0.0.1:8000
NEXT_PUBLIC_CLAIMDONE_PORTAL_ORIGIN=http://127.0.0.1:3000
CLAIMDONE_WEB_ORIGIN=http://127.0.0.1:3000
CLAIMDONE_PORTAL_ORIGIN=http://127.0.0.1:3000

# Server-only local portal control. Never prefix this variable with NEXT_PUBLIC_.
CLAIMDONE_PORTAL_CONTROL_TOKEN=replace-with-a-random-server-only-token-of-at-least-32-characters
