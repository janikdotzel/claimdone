{
  "$defs": {
    "ActorType": {
      "enum": [
        "system",
        "agent",
        "human"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "AllowedTool": {
      "enum": [
        "inspect_evidence",
        "check_required_fields",
        "ask_clarification",
        "inspect_form",
        "fill_until_review",
        "verify_rendered_fields",
        "read_receipt"
      ],
      "title": "AllowedTool",
      "type": "string"
    },
    "AuditDetail": {
      "additionalProperties": false,
      "description": "A deliberately redacted audit attribute.",
      "properties": {
        "key": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Key",
          "type": "string"
        },
        "redacted": {
          "const": true,
          "title": "Redacted",
          "type": "boolean"
        },
        "valueSummary": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Valuesummary",
          "type": "string"
        }
      },
      "required": [
        "key",
        "valueSummary",
        "redacted"
      ],
      "title": "AuditDetail",
      "type": "object"
    },
    "AuditEvent": {
      "additionalProperties": false,
      "description": "Redacted event suitable for persistence and the UI event strip.",
      "properties": {
        "actor": {
          "$ref": "#/$defs/ActorType"
        },
        "caseId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Caseid",
          "type": "string"
        },
        "contractVersion": {
          "const": "1.0.0",
          "title": "Contractversion",
          "type": "string"
        },
        "details": {
          "items": {
            "$ref": "#/$defs/AuditDetail"
          },
          "title": "Details",
          "type": "array"
        },
        "eventId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Eventid",
          "type": "string"
        },
        "eventType": {
          "$ref": "#/$defs/AuditEventType"
        },
        "fromState": {
          "anyOf": [
            {
              "$ref": "#/$defs/CaseState"
            },
            {
              "type": "null"
            }
          ]
        },
        "occurredAt": {
          "format": "date-time",
          "title": "Occurredat",
          "type": "string"
        },
        "reasonCodes": {
          "items": {
            "$ref": "#/$defs/GateReasonCode"
          },
          "title": "Reasoncodes",
          "type": "array"
        },
        "toState": {
          "anyOf": [
            {
              "$ref": "#/$defs/CaseState"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "contractVersion",
        "eventId",
        "caseId",
        "eventType",
        "actor",
        "occurredAt",
        "fromState",
        "toState",
        "reasonCodes",
        "details"
      ],
      "title": "AuditEvent",
      "type": "object"
    },
    "AuditEventType": {
      "enum": [
        "case_state_changed",
        "gate_decision",
        "plan_step",
        "tool_call",
        "verification",
        "human_approval",
        "receipt",
        "reset"
      ],
      "title": "AuditEventType",
      "type": "string"
    },
    "CaseState": {
      "description": "Canonical orchestrator states.",
      "enum": [
        "created",
        "disclosed",
        "analyzing",
        "awaiting_clarification",
        "ready_to_fill",
        "filling",
        "verifying",
        "review",
        "blocked",
        "human_approved",
        "receipt",
        "emergency_stopped",
        "abandoned",
        "failed"
      ],
      "title": "CaseState",
      "type": "string"
    },
    "CheckpointStatus": {
      "enum": [
        "pending",
        "passed",
        "failed"
      ],
      "title": "CheckpointStatus",
      "type": "string"
    },
    "ClaimData": {
      "additionalProperties": false,
      "description": "The complete draft payload and deterministic required-field result.",
      "properties": {
        "attachments": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 3,
          "minItems": 3,
          "title": "Attachments",
          "type": "array"
        },
        "claimantName": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Claimantname"
        },
        "counterpartyKnown": {
          "$ref": "#/$defs/CounterpartyKnown"
        },
        "fieldProvenance": {
          "items": {
            "$ref": "#/$defs/FieldProvenance"
          },
          "title": "Fieldprovenance",
          "type": "array"
        },
        "incidentDate": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Incidentdate"
        },
        "incidentTime": {
          "anyOf": [
            {
              "format": "time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Incidenttime"
        },
        "location": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Location"
        },
        "missingRequiredFields": {
          "items": {
            "$ref": "#/$defs/RequiredClaimField"
          },
          "title": "Missingrequiredfields",
          "type": "array"
        },
        "narrative": {
          "anyOf": [
            {
              "maxLength": 4000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Narrative"
        },
        "policyReference": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Policyreference"
        },
        "vehicleRegistration": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Vehicleregistration"
        }
      },
      "required": [
        "incidentDate",
        "incidentTime",
        "location",
        "claimantName",
        "policyReference",
        "vehicleRegistration",
        "counterpartyKnown",
        "narrative",
        "attachments",
        "missingRequiredFields",
        "fieldProvenance"
      ],
      "title": "ClaimData",
      "type": "object"
    },
    "ClaimPacket": {
      "additionalProperties": false,
      "description": "Canonical evidence-linked claim draft consumed by every subsystem.",
      "properties": {
        "caseId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Caseid",
          "type": "string"
        },
        "claim": {
          "$ref": "#/$defs/ClaimData"
        },
        "contractVersion": {
          "const": "1.0.0",
          "title": "Contractversion",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceItem"
          },
          "minItems": 4,
          "title": "Evidence",
          "type": "array"
        },
        "facts": {
          "items": {
            "$ref": "#/$defs/EvidenceFact"
          },
          "title": "Facts",
          "type": "array"
        },
        "gateDecisions": {
          "items": {
            "$ref": "#/$defs/GateDecision"
          },
          "title": "Gatedecisions",
          "type": "array"
        },
        "plan": {
          "$ref": "#/$defs/ToolPlan"
        },
        "portalState": {
          "$ref": "#/$defs/PortalState"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/ProvenanceRef"
          },
          "minItems": 1,
          "title": "Provenance",
          "type": "array"
        },
        "scope": {
          "$ref": "#/$defs/ClaimScope"
        },
        "state": {
          "$ref": "#/$defs/CaseState"
        },
        "verification": {
          "$ref": "#/$defs/VerificationReport"
        }
      },
      "required": [
        "contractVersion",
        "caseId",
        "state",
        "portalState",
        "scope",
        "evidence",
        "provenance",
        "facts",
        "claim",
        "plan",
        "gateDecisions",
        "verification"
      ],
      "title": "ClaimPacket",
      "type": "object"
    },
    "ClaimScope": {
      "additionalProperties": false,
      "description": "Immutable sandbox and final-action authority boundary.",
      "properties": {
        "agentCanSubmit": {
          "const": false,
          "title": "Agentcansubmit",
          "type": "boolean"
        },
        "environment": {
          "const": "sandbox",
          "title": "Environment",
          "type": "string"
        },
        "finalActionOwner": {
          "const": "human",
          "title": "Finalactionowner",
          "type": "string"
        },
        "scenario": {
          "const": "two_vehicle_rear_end_no_injury",
          "title": "Scenario",
          "type": "string"
        }
      },
      "required": [
        "environment",
        "scenario",
        "agentCanSubmit",
        "finalActionOwner"
      ],
      "title": "ClaimScope",
      "type": "object"
    },
    "CounterpartyKnown": {
      "enum": [
        "yes",
        "no",
        "unknown"
      ],
      "title": "CounterpartyKnown",
      "type": "string"
    },
    "DeterministicEvalExpectation": {
      "additionalProperties": false,
      "description": "A binary or structured check that never delegates to a model grader.",
      "properties": {
        "checkId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Checkid",
          "type": "string"
        },
        "deterministic": {
          "const": true,
          "title": "Deterministic",
          "type": "boolean"
        },
        "expectedPassed": {
          "title": "Expectedpassed",
          "type": "boolean"
        },
        "expectedReasonCodes": {
          "items": {
            "$ref": "#/$defs/GateReasonCode"
          },
          "title": "Expectedreasoncodes",
          "type": "array"
        }
      },
      "required": [
        "checkId",
        "deterministic",
        "expectedPassed",
        "expectedReasonCodes"
      ],
      "title": "DeterministicEvalExpectation",
      "type": "object"
    },
    "EvalCase": {
      "additionalProperties": false,
      "description": "Versioned eval input and ground truth, usable without a live model.",
      "properties": {
        "contractVersion": {
          "const": "1.0.0",
          "title": "Contractversion",
          "type": "string"
        },
        "evalId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Evalid",
          "type": "string"
        },
        "evaluationMode": {
          "$ref": "#/$defs/EvaluationMode"
        },
        "expectation": {
          "$ref": "#/$defs/EvalExpectation"
        },
        "input": {
          "$ref": "#/$defs/EvalInput"
        },
        "priority": {
          "$ref": "#/$defs/EvalPriority"
        },
        "releaseBlocking": {
          "title": "Releaseblocking",
          "type": "boolean"
        },
        "tags": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "title": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "contractVersion",
        "evalId",
        "title",
        "priority",
        "evaluationMode",
        "releaseBlocking",
        "tags",
        "input",
        "expectation"
      ],
      "title": "EvalCase",
      "type": "object"
    },
    "EvalExpectation": {
      "additionalProperties": false,
      "description": "Complete, machine-readable ground truth for an eval case.",
      "properties": {
        "allowedFacts": {
          "items": {
            "$ref": "#/$defs/FactExpectation"
          },
          "title": "Allowedfacts",
          "type": "array"
        },
        "allowedTools": {
          "items": {
            "$ref": "#/$defs/AllowedTool"
          },
          "title": "Allowedtools",
          "type": "array"
        },
        "deterministicChecks": {
          "items": {
            "$ref": "#/$defs/DeterministicEvalExpectation"
          },
          "minItems": 1,
          "title": "Deterministicchecks",
          "type": "array"
        },
        "expectedClarification": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Expectedclarification"
        },
        "expectedFinalState": {
          "$ref": "#/$defs/CaseState"
        },
        "expectedGateDecisions": {
          "items": {
            "$ref": "#/$defs/ExpectedGateDecision"
          },
          "minItems": 1,
          "title": "Expectedgatedecisions",
          "type": "array"
        },
        "expectedMissingFields": {
          "items": {
            "$ref": "#/$defs/RequiredClaimField"
          },
          "title": "Expectedmissingfields",
          "type": "array"
        },
        "expectedPortalValues": {
          "items": {
            "$ref": "#/$defs/PortalValueExpectation"
          },
          "title": "Expectedportalvalues",
          "type": "array"
        },
        "expectedToolSequence": {
          "items": {
            "$ref": "#/$defs/AllowedTool"
          },
          "title": "Expectedtoolsequence",
          "type": "array"
        },
        "expectedVerificationState": {
          "$ref": "#/$defs/VerificationState"
        },
        "forbiddenFactFields": {
          "items": {
            "$ref": "#/$defs/EvidenceField"
          },
          "title": "Forbiddenfactfields",
          "type": "array"
        },
        "modelGraderThresholds": {
          "items": {
            "$ref": "#/$defs/ModelGraderExpectation"
          },
          "title": "Modelgraderthresholds",
          "type": "array"
        }
      },
      "required": [
        "allowedFacts",
        "forbiddenFactFields",
        "expectedMissingFields",
        "expectedClarification",
        "allowedTools",
        "expectedToolSequence",
        "expectedGateDecisions",
        "expectedPortalValues",
        "expectedVerificationState",
        "expectedFinalState",
        "deterministicChecks",
        "modelGraderThresholds"
      ],
      "title": "EvalExpectation",
      "type": "object"
    },
    "EvalInput": {
      "additionalProperties": false,
      "description": "Non-sensitive fixture references and natural-language input.",
      "properties": {
        "fixtureIds": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Fixtureids",
          "type": "array"
        },
        "language": {
          "enum": [
            "de",
            "en"
          ],
          "title": "Language",
          "type": "string"
        },
        "portalVariant": {
          "enum": [
            "A",
            "B"
          ],
          "title": "Portalvariant",
          "type": "string"
        },
        "statement": {
          "anyOf": [
            {
              "maxLength": 4000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Statement"
        },
        "transcript": {
          "anyOf": [
            {
              "maxLength": 4000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Transcript"
        }
      },
      "required": [
        "fixtureIds",
        "statement",
        "transcript",
        "language",
        "portalVariant"
      ],
      "title": "EvalInput",
      "type": "object"
    },
    "EvalPriority": {
      "enum": [
        "P0",
        "P1",
        "P2"
      ],
      "title": "EvalPriority",
      "type": "string"
    },
    "EvaluationMode": {
      "enum": [
        "deterministic",
        "live",
        "hybrid"
      ],
      "title": "EvaluationMode",
      "type": "string"
    },
    "EvidenceFact": {
      "additionalProperties": false,
      "description": "A bounded fact with explicit support status and source references.",
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Confidence"
        },
        "factId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Factid",
          "type": "string"
        },
        "field": {
          "$ref": "#/$defs/EvidenceField"
        },
        "sourceRefs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "title": "Sourcerefs",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/FactStatus"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "factId",
        "field",
        "value",
        "status",
        "sourceRefs",
        "confidence"
      ],
      "title": "EvidenceFact",
      "type": "object"
    },
    "EvidenceField": {
      "enum": [
        "visible_damage",
        "collision_type",
        "vehicle_count",
        "impact_area",
        "incident_date",
        "incident_time",
        "location",
        "claimant_name",
        "policy_reference",
        "vehicle_registration",
        "counterparty_known",
        "narrative",
        "injury_status",
        "immediate_danger"
      ],
      "title": "EvidenceField",
      "type": "string"
    },
    "EvidenceItem": {
      "additionalProperties": false,
      "description": "A local, content-addressed evidence input approved for the active case.",
      "properties": {
        "evidenceId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Evidenceid",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "localRef": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Localref",
          "type": "string"
        },
        "mediaType": {
          "enum": [
            "image/jpeg",
            "image/png",
            "text/plain"
          ],
          "title": "Mediatype",
          "type": "string"
        },
        "modelCopyApproved": {
          "title": "Modelcopyapproved",
          "type": "boolean"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "text": {
          "anyOf": [
            {
              "maxLength": 4000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Text"
        }
      },
      "required": [
        "evidenceId",
        "kind",
        "localRef",
        "mediaType",
        "sha256",
        "text",
        "modelCopyApproved"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "EvidenceKind": {
      "enum": [
        "image",
        "user_statement",
        "transcript",
        "clarification"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "ExpectedGateDecision": {
      "additionalProperties": false,
      "description": "Expected deterministic outcome for one gate in an eval case.",
      "properties": {
        "deterministic": {
          "const": true,
          "title": "Deterministic",
          "type": "boolean"
        },
        "gateId": {
          "$ref": "#/$defs/GateId"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "reasonCodes": {
          "items": {
            "$ref": "#/$defs/GateReasonCode"
          },
          "title": "Reasoncodes",
          "type": "array"
        }
      },
      "required": [
        "gateId",
        "deterministic",
        "passed",
        "reasonCodes"
      ],
      "title": "ExpectedGateDecision",
      "type": "object"
    },
    "FactExpectation": {
      "additionalProperties": false,
      "description": "Ground truth for one allowed evidence fact.",
      "properties": {
        "field": {
          "$ref": "#/$defs/EvidenceField"
        },
        "minimumConfidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Minimumconfidence"
        },
        "status": {
          "$ref": "#/$defs/FactStatus"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "field",
        "status",
        "value",
        "minimumConfidence"
      ],
      "title": "FactExpectation",
      "type": "object"
    },
    "FactStatus": {
      "description": "How strongly an evidence fact is supported.",
      "enum": [
        "observed",
        "user_stated",
        "unknown",
        "not_supported"
      ],
      "title": "FactStatus",
      "type": "string"
    },
    "FieldProvenance": {
      "additionalProperties": false,
      "description": "All source pointers supporting one portal-writable claim field.",
      "properties": {
        "field": {
          "$ref": "#/$defs/RequiredClaimField"
        },
        "sourceRefs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "minItems": 1,
